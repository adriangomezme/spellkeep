{
  "expo": {
    "name": "SpellKeep",
    "slug": "spellkeep",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "spellkeep",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F5F7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.spellkeep.app",
      "infoPlist": {
        "NSCameraUsageDescription": "SpellKeep needs camera access to scan Magic cards"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F5F7"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.spellkeep.app",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "@journeyapps/react-native-quick-sqlite",
      "react-native-vision-camera",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#023BFD"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "04db0fe5-3237-4b76-a876-557989db7070"
      }
    },
    "owner": "spellkeep"
  }
}
